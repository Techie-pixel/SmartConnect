<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Focused state — blue border -->
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="#0D2540" />
            <stroke android:width="2dp" android:color="#2979FF" />
            <corners android:radius="10dp" />
            <padding android:left="12dp" android:top="8dp" android:right="12dp" android:bottom="8dp" />
        </shape>
    </item>

    <!-- Default state — dark subtle border -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#0D2540" />
            <stroke android:width="1.5dp" android:color="#1E3A55" />
            <corners android:radius="10dp" />
            <padding android:left="12dp" android:top="8dp" android:right="12dp" android:bottom="8dp" />
        </shape>
    </item>

</selector>