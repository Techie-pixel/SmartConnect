<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/gradient1">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <androidx.appcompat.widget.Toolbar
            app:titleTextColor="#FFFFFF"
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:background="#1B477C"
            android:paddingTop="20dp"
            android:theme="@style/ThemeOverlay.AppCompat.Light" />

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <LinearLayout
                android:id="@+id/contentLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                tools:context=".PrincipalExamActivity"
                android:orientation="vertical"
                android:padding="16dp">

                <ImageView
                    android:id="@+id/logoImg"
                    android:layout_width="300dp"
                    android:layout_height="300dp"
                    android:layout_gravity="center"
                    android:src="@drawable/projectlogo"
                    android:contentDescription="Logo"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="20dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Upload Exam Schedule"
                    android:textSize="25dp"
                    android:layout_gravity="center"
                    android:textColor="@color/white"
                    android:textStyle="bold"
                    android:layout_marginBottom="20dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Select Standard"
                    android:textSize="18dp"
                    android:textColor="@color/white"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/gradient2"
                    android:padding="12dp"
                    android:layout_marginBottom="16dp">
                    <RadioGroup
                        android:id="@+id/standardRadioGroup"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <RadioButton android:id="@+id/radio11" android:layout_width="0dp"
                            android:layout_height="wrap_content" android:layout_weight="1"
                            android:text="11" android:textColor="@color/black" android:textStyle="bold"/>
                        <RadioButton android:id="@+id/radio12" android:layout_width="0dp"
                            android:layout_height="wrap_content" android:layout_weight="1"
                            android:text="12" android:textColor="@color/black" android:textStyle="bold"/>
                        <RadioButton android:id="@+id/radioAll" android:layout_width="0dp"
                            android:layout_height="wrap_content" android:layout_weight="1"
                            android:text="All" android:textColor="@color/black" android:textStyle="bold"/>
                    </RadioGroup>
                </LinearLayout>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Select Stream" android:textSize="18dp"
                    android:textColor="@color/white" android:textStyle="bold" android:layout_marginBottom="8dp"/>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:background="@drawable/gradient2"
                    android:padding="12dp" android:layout_marginBottom="16dp">
                    <CheckBox android:id="@+id/checkScience" android:layout_width="match_parent"
                        android:layout_height="wrap_content" android:text="Science"
                        android:textStyle="bold" android:textColor="@color/black"/>
                    <CheckBox android:id="@+id/checkCommerce" android:layout_width="match_parent"
                        android:layout_height="wrap_content" android:text="Commerce"
                        android:textStyle="bold" android:textColor="@color/black"/>
                    <CheckBox android:id="@+id/checkArts" android:layout_width="match_parent"
                        android:layout_height="wrap_content" android:text="Arts"
                        android:textStyle="bold" android:textColor="@color/black"/>
                    <CheckBox android:id="@+id/checkAllStreams" android:layout_width="match_parent"
                        android:layout_height="wrap_content" android:text="All Streams"
                        android:textColor="@color/black" android:textStyle="bold"/>
                </LinearLayout>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Select Exam Type" android:textSize="18dp"
                    android:textColor="@color/white" android:textStyle="bold" android:layout_marginBottom="8dp"/>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:background="@drawable/gradient2"
                    android:padding="12dp" android:layout_marginBottom="16dp">
                    <RadioGroup android:id="@+id/examTypeRadioGroup"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="vertical">
                        <RadioButton android:id="@+id/radioUnitTest" android:layout_width="match_parent"
                            android:layout_height="wrap_content" android:text="Unit Test"
                            android:textColor="@color/black" android:textStyle="bold"/>
                        <RadioButton android:id="@+id/radioMidTerm" android:layout_width="match_parent"
                            android:layout_height="wrap_content" android:text="Mid Term"
                            android:textColor="@color/black" android:textStyle="bold"/>
                        <RadioButton android:id="@+id/radioFinalExam" android:layout_width="match_parent"
                            android:layout_height="wrap_content" android:text="Final Exam"
                            android:textColor="@color/black" android:textStyle="bold"/>
                        <RadioButton android:id="@+id/radioPractical" android:layout_width="match_parent"
                            android:layout_height="wrap_content" android:text="Practical"
                            android:textColor="@color/black" android:textStyle="bold"/>
                    </RadioGroup>
                </LinearLayout>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Share with Teachers" android:textSize="18dp"
                    android:textColor="@color/white" android:textStyle="bold" android:layout_marginBottom="8dp"/>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:background="@drawable/gradient2"
                    android:padding="12dp" android:layout_marginBottom="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="You want to share this exam schedule with teachers also?"
                        android:textSize="16sp" android:textColor="@color/black"
                        android:textStyle="bold" android:layout_marginBottom="8dp"/>
                    <RadioGroup android:id="@+id/shareTeacherRadioGroup"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <RadioButton android:id="@+id/radioYes" android:layout_width="0dp"
                            android:layout_height="wrap_content" android:layout_weight="1"
                            android:text="Yes" android:textColor="@color/black" android:textStyle="bold"/>
                        <RadioButton android:id="@+id/radioNo" android:layout_width="0dp"
                            android:layout_height="wrap_content" android:layout_weight="1"
                            android:text="No" android:textColor="@color/black" android:textStyle="bold"/>
                    </RadioGroup>
                </LinearLayout>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Assign Teacher (Optional)" android:textSize="18dp"
                    android:textColor="@color/white" android:textStyle="bold" android:layout_marginBottom="8dp"/>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:background="@drawable/gradient2"
                    android:padding="12dp" android:layout_marginBottom="16dp">
                    <Spinner android:id="@+id/teacherSpinner"
                        android:layout_width="match_parent" android:layout_height="50dp"
                        android:backgroundTint="@color/black" />
                </LinearLayout>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Write Exam Information (Optional)" android:layout_marginTop="20dp"
                    android:textSize="18dp" android:textColor="@color/white"
                    android:textStyle="bold" android:layout_marginBottom="8dp"/>

                <EditText android:id="@+id/examInfoEdit"
                    android:layout_width="match_parent" android:layout_height="150dp"
                    android:background="@drawable/gradient2" android:padding="12dp"
                    android:gravity="top|start" android:textStyle="bold"
                    android:hint="Enter exam details, date, time, venue..."
                    android:textColorHint="@color/black" android:textColor="@color/black"
                    android:inputType="textMultiLine" android:layout_marginBottom="16dp"/>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Add Image (Optional)" android:textSize="18dp"
                    android:textColor="@color/white" android:textStyle="bold" android:layout_marginBottom="8dp"/>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="16dp">
                    <Button android:id="@+id/cameraBtn" android:layout_width="0dp"
                        android:layout_height="wrap_content" android:layout_weight="1"
                        android:text="Camera" android:textStyle="bold" android:textColor="@color/white"
                        android:drawableTop="@android:drawable/ic_menu_camera"
                        android:padding="12dp" android:layout_marginEnd="8dp" android:backgroundTint="#0A2C56"/>
                    <Button android:id="@+id/galleryBtn" android:layout_width="0dp"
                        android:layout_height="wrap_content" android:layout_weight="1"
                        android:text="Gallery" android:textStyle="bold" android:textColor="@color/white"
                        android:drawableTop="@android:drawable/ic_menu_gallery"
                        android:padding="12dp" android:layout_marginStart="8dp" android:backgroundTint="#0A2C56"/>
                </LinearLayout>

                <LinearLayout android:id="@+id/imagePreviewContainer"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:visibility="gone"
                    android:background="@drawable/gradient2" android:padding="12dp"
                    android:layout_marginBottom="16dp">
                    <ImageView android:id="@+id/previewImage"
                        android:layout_width="match_parent" android:layout_height="200dp"
                        android:scaleType="centerCrop" android:contentDescription="Exam Schedule Image Preview"/>
                    <Button android:id="@+id/removeImageBtn"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_gravity="center" android:text="Remove Image"
                        android:backgroundTint="#F44336" android:layout_marginTop="8dp"/>
                </LinearLayout>

                <!-- Upload Button -->
                <Button android:id="@+id/submitBtn"
                    android:layout_width="match_parent" android:layout_height="60dp"
                    android:text="Upload" android:textColor="@color/white"
                    android:backgroundTint="#0A2C56" android:textSize="18sp"
                    android:textStyle="bold" android:layout_marginTop="8dp"
                    android:layout_marginBottom="24dp"/>

                <!-- ===================== MANAGE HISTORY ===================== -->
                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="#2A4A7F" android:layout_marginBottom="16dp"/>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="📋  Manage History" android:textSize="20dp"
                    android:textColor="@color/white" android:textStyle="bold"
                    android:layout_marginBottom="12dp"/>

                <ProgressBar android:id="@+id/historyProgressBar"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_gravity="center" android:visibility="visible"
                    android:layout_marginBottom="8dp"/>

                <TextView android:id="@+id/tvNoHistory"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="No exam schedules uploaded yet."
                    android:textColor="#888888" android:textSize="14sp"
                    android:layout_gravity="center" android:visibility="gone"
                    android:layout_marginBottom="16dp"/>

                <LinearLayout android:id="@+id/historyContainer"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:layout_marginBottom="16dp"/>

            </LinearLayout>
        </ScrollView>
    </LinearLayout>

    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navigationview"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="#0A1628"
        app:menu="@menu/principal_drawer_menu"
        app:headerLayout="@layout/nav_header"
        app:itemTextColor="#FFFFFF"
        app:itemIconTint="#A3BFFA" />

</androidx.drawerlayout.widget.DrawerLayout>