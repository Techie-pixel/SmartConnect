<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".studentprofile"
    android:background="@drawable/gradient1">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingBottom="40dp">

            <ImageView
                android:id="@+id/profileIcon"
                android:layout_width="300dp"
                android:layout_height="300dp"
                android:layout_marginTop="32dp"
                android:src="@drawable/projectlogo"/>

            <de.hdodenhof.circleimageview.CircleImageView
                android:id="@+id/profileImage"
                android:layout_width="240dp"
                android:layout_height="240dp"
                app:civ_border_width="2dp"
                app:civ_border_color="#1976D2"
                android:src="@drawable/ic_default_profile"
                android:layout_marginTop="20dp"/>

            <EditText
                android:id="@+id/profileName"
                android:layout_width="350dp"
                android:layout_height="wrap_content"
                android:hint="Name"
                android:textStyle="bold"
                android:textSize="20sp"
                android:textColor="#222"
                android:background="@drawable/gradient2"
                android:enabled="false"
                android:layout_marginTop="18dp"/>

            <EditText
                android:id="@+id/profileStd"
                android:layout_width="350dp"
                android:layout_height="wrap_content"
                android:hint="Standard"
                android:textStyle="bold"
                android:textSize="18sp"
                android:textColor="@color/black"
                android:background="@drawable/gradient2"
                android:enabled="false"
                android:layout_marginTop="10dp"/>

            <EditText
                android:id="@+id/profileStream"
                android:layout_width="350dp"
                android:layout_height="wrap_content"
                android:hint="Stream"
                android:textStyle="bold"
                android:textSize="18sp"
                android:textColor="@color/black"
                android:background="@drawable/gradient2"
                android:enabled="false"
                android:layout_marginTop="10dp"/>

            <EditText
                android:id="@+id/profileMobile"
                android:layout_width="350dp"
                android:layout_height="wrap_content"
                android:hint="Mobile Number"
                android:textColor="#222"
                android:textStyle="bold"
                android:textSize="18sp"
                android:background="@drawable/gradient2"
                android:enabled="false"
                android:layout_marginTop="10dp"/>

            <Button
                android:id="@+id/blockBtn"
                android:layout_width="180dp"
                android:layout_height="wrap_content"
                android:text="Block"
                android:textStyle="bold"
                android:textSize="16sp"
                android:textColor="#fff"
                android:backgroundTint="#0A2C56"
                android:layout_marginTop="18dp"/>
        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
