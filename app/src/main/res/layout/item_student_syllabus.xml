<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="12dp"
    android:layout_marginEnd="12dp"
    android:layout_marginTop="6dp"
    android:layout_marginBottom="6dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="#1A2E55">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Top Row: Syllabus info + unread badge -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvSyllabusTarget"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#A3BFFA"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:text="Syllabus" />

                <TextView
                    android:id="@+id/tvSyllabusDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#7B9ED9"
                    android:textSize="11sp"
                    android:layout_marginTop="2dp"
                    android:text="Date" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvUnreadBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="NEW"
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                android:textStyle="bold"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:background="@drawable/gradient5"
                android:visibility="gone" />
        </LinearLayout>

        <!-- Syllabus text -->
        <TextView
            android:id="@+id/tvSyllabusInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:layout_marginTop="10dp"
            android:text="Syllabus Text" />

        <!-- Syllabus Image -->
        <ImageView
            android:id="@+id/ivSyllabusImage"
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:scaleType="centerCrop"
            android:layout_marginTop="10dp"
            android:visibility="gone"
            android:contentDescription="Syllabus Image" />

        <!-- Action Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end"
            android:layout_marginTop="10dp">
            
            <Button
                android:id="@+id/btnDownload"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="Download"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:textAllCaps="false"
                android:backgroundTint="#1565C0"
                android:layout_marginEnd="8dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:visibility="gone"/>

            <Button
                android:id="@+id/btnMarkRead"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="✓ Mark as Read"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:textAllCaps="false"
                android:backgroundTint="#2E7D32"
                android:paddingStart="16dp"
                android:paddingEnd="16dp" />
        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>
