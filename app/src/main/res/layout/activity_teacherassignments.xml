<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/gradient1">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <androidx.appcompat.widget.Toolbar
            app:titleTextColor="#FFFFFF"
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:background="#1B477C"
            android:paddingTop="20dp"
            android:theme="@style/ThemeOverlay.AppCompat.Light" />

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                tools:context=".teacherassignments">

        <!-- Logo -->
        <ImageView
            android:id="@+id/logoImg"
            android:layout_width="300dp"
            android:layout_height="300dp"
            android:layout_gravity="center"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="16dp"
            android:src="@drawable/projectlogo" />



        <EditText
            android:id="@+id/etTitle"
            android:layout_marginTop="30dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Enter Subject name"
            android:background="@drawable/gradient2"
            android:textColor="@android:color/black"
            android:textColorHint="@android:color/black"
            android:padding="16dp"
            android:maxLines="1"
            android:layout_marginBottom="12dp" />


        <EditText
            android:id="@+id/etTeacherName"
            android:layout_marginTop="10dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Enter teacher name"
            android:background="@drawable/gradient2"
            android:textColor="@android:color/black"
            android:textColorHint="@android:color/black"
            android:padding="16dp"
            android:maxLines="1"
            android:layout_marginBottom="12dp" />

        <!-- Standard Dropdown -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Select Standard"
            android:textColor="@android:color/white"
            android:textSize="15sp"
            android:textStyle="bold"
            android:layout_marginBottom="6dp" />

        <Spinner
            android:id="@+id/spinnerStandard"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/gradient2"
            android:padding="12dp"
            android:layout_marginBottom="12dp" />

        <!-- Stream Dropdown -->
        <TextView
            android:layout_width="match_parent"
            android:layout_marginTop="10dp"
            android:layout_height="wrap_content"
            android:text="Select Stream"
            android:textColor="@android:color/white"
            android:textSize="15sp"
            android:textStyle="bold"
            android:layout_marginBottom="6dp" />

        <Spinner
            android:id="@+id/spinnerStream"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/gradient2"
            android:padding="12dp"
            android:layout_marginBottom="16dp" />

        <!-- Due Date & Time -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Select Submission Deadline"
            android:textColor="@android:color/white"
            android:textSize="15sp"
            android:textStyle="bold"
            android:layout_marginBottom="6dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="2"
            android:layout_marginBottom="16dp">

            <Button
                android:id="@+id/btnPickDate"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:text="Pick Date"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:backgroundTint="#0A2C56" />

            <Space
                android:layout_width="8dp"
                android:layout_height="match_parent" />

            <Button
                android:id="@+id/btnPickTime"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:text="Pick Time"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:backgroundTint="#0A2C56" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvDueSummary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@android:color/white"
            android:textSize="14sp"
            android:layout_marginBottom="8dp"
            android:visibility="gone"/>



        <EditText
            android:id="@+id/etDescription"
            android:layout_marginTop="10dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Enter instructions or questions..."
            android:background="@drawable/gradient2"
            android:textColor="@android:color/black"
            android:textColorHint="@android:color/black"
            android:padding="16dp"
            android:minHeight="120dp"
            android:gravity="top"
            android:inputType="textMultiLine"
            android:scrollbars="vertical"
            android:maxLines="10"
            android:layout_marginBottom="16dp" />

        <!-- File Selection Buttons (Only Gallery and Camera) -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📎 Add Image (Max 1)"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="2"
            android:layout_marginBottom="16dp">

            <Button
                android:id="@+id/btnGallery"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:text="Gallery"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:drawableTop="@android:drawable/ic_menu_gallery"
                android:padding="14dp"
                android:backgroundTint="#0A2C56"
                />

            <Button
                android:id="@+id/btnPhoto"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:text="Camera"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:textStyle="bold"
                android:drawableTop="@android:drawable/ic_menu_camera"
                android:padding="14dp"
                android:backgroundTint="#0A2C56"
                />
        </LinearLayout>

        <!-- Selected Files Preview -->
        <TextView
            android:id="@+id/tvFilesLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Selected Images:"
            android:textColor="@android:color/black"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"
            android:visibility="gone" />

        <!-- RecyclerView for displaying selected images in grid/horizontal -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvAttachments"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:nestedScrollingEnabled="false"
            android:visibility="gone" />

        <!-- Upload Button -->
        <Button
            android:id="@+id/btnUpload"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="Upload Assignment"
            android:textSize="18dp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:backgroundTint="#0A2C56"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="16dp" />

        <Button
            android:id="@+id/btnManageSubmissions"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="Manage Submissions"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:backgroundTint="#1B477C"
            android:layout_marginBottom="16dp"/>

            </LinearLayout>
        </ScrollView>
    </LinearLayout>

    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navigationview"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="#0A1628"
        app:menu="@menu/teacher_drawer_menu"
        app:headerLayout="@layout/nav_header"
        app:itemTextColor="#FFFFFF"
        app:itemIconTint="#A3BFFA" />
</androidx.drawerlayout.widget.DrawerLayout>
