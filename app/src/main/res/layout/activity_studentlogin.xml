<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@drawable/gradient1"
    tools:context=".studentlogin">

    <LinearLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingBottom="30dp">

        <!-- App Logo -->
        <ImageView
            android:layout_width="400dp"
            android:layout_height="350dp"
            android:layout_gravity="center"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="20dp"
            android:contentDescription="App Logo"
            android:src="@drawable/projectlogo" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Student Login"
            android:textColor="@color/white"
            android:gravity="center"
            android:textStyle="bold"
            android:textSize="30dp">
        </TextView>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Learning is the key to success"
            android:textColor="@color/white"
            android:gravity="center"
            android:layout_marginTop="12dp"
            android:textStyle="bold"
            android:textSize="15dp">
        </TextView>

        <!-- Email Field -->
        <EditText
            android:id="@+id/loginEmail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Enter Your Email"
            android:padding="15dp"
            android:textColor="@color/black"
            android:textColorHint="#100F0F"
            android:layout_marginTop="50dp"
            android:layout_marginLeft="20dp"
            android:layout_marginRight="20dp"
            android:background="@drawable/gradient2" />

        <!-- Password Field -->
        <EditText
            android:id="@+id/loginPassword"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Enter Your Password"
            android:padding="15dp"
            android:inputType="textPassword"
            android:textColor="@color/black"
            android:textColorHint="#100F0F"
            android:layout_marginTop="30dp"
            android:layout_marginLeft="20dp"
            android:layout_marginRight="20dp"
            android:background="@drawable/gradient2"
            android:drawableEnd="@drawable/eyeoff"
            android:drawablePadding="10dp"/>


        <!-- Forget Password -->

        <!-- Login Button -->
        <TextView
            android:id="@+id/forgetPassword"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="10dp"
            android:text="Forget Password?"
            android:textColor="@color/white"
            android:textSize="18dp"
            android:layout_marginRight="110dp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/loginButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Login"
            android:textStyle="bold"
            android:textSize="18dp"
            android:textColor="@android:color/white"
            android:backgroundTint="#0A2C56"
            android:layout_margin="20dp"
            android:layout_marginTop="30dp"
            android:padding="12dp"
            android:fontFamily="sans-serif-medium" />

        <!-- New User Text -->
        <TextView
            android:id="@+id/clickhere"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="New user? Click here!!"
            android:textColor="@color/white"
            android:textSize="18dp"
            android:textStyle="bold"
            android:layout_gravity="center"
            android:layout_marginTop="10dp" />

    </LinearLayout>
</ScrollView>
