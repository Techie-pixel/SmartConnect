<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".studentcalender">

    <LinearLayout
        android:id="@+id/main_content"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="#0F1B35">

        <!-- Top App Bar -->
        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:background="#1B477C"
            android:elevation="4dp"
            android:paddingTop="@dimen/status_bar_height"
            app:titleTextColor="#FFFFFF"
            android:theme="@style/ThemeOverlay.AppCompat.Light" />
            <!-- The original paddingStart and paddingEnd were removed as per the provided Code Edit block.
                 The original app:title was also removed as per the provided Code Edit block. -->

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:background="#0F1B35">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="32dp">

                <ImageView
                    android:layout_width="300dp"
                    android:layout_height="300dp"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="16dp"
                    android:layout_gravity="center"
                    android:src="@drawable/projectlogo"
                    android:contentDescription="App Logo" />

                <!-- Header Card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp"
                    android:layout_marginTop="8dp"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#1A2E55">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="👋 Welcome Back!"
                            android:textColor="#A3BFFA"
                            android:textSize="13sp"
                            android:letterSpacing="0.08" />

                        <TextView
                            android:id="@+id/calendarMessage"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Student Calendar"
                            android:textColor="#FFFFFF"
                            android:textSize="26sp"
                            android:textStyle="bold"
                            android:layout_marginTop="4dp" />

                        <TextView
                            android:id="@+id/todayDateText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Thursday, 26 February 2026"
                            android:textColor="#7B9ED9"
                            android:textSize="13sp"
                            android:layout_marginTop="4dp" />

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Calendar View Card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp"
                    android:layout_marginTop="16dp"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#1A2E55">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <!-- Month Navigation — text arrows, NO drawable needed -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="12dp">

                            <TextView
                                android:id="@+id/btnPrevMonth"
                                android:layout_width="36dp"
                                android:layout_height="36dp"
                                android:gravity="center"
                                android:text="‹"
                                android:textColor="#A3BFFA"
                                android:textSize="26sp"
                                android:textStyle="bold"
                                android:background="#1E3A6E" />

                            <TextView
                                android:id="@+id/monthYearText"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:gravity="center"
                                android:text="February 2026"
                                android:textColor="#FFFFFF"
                                android:textSize="18sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/btnNextMonth"
                                android:layout_width="36dp"
                                android:layout_height="36dp"
                                android:gravity="center"
                                android:text="›"
                                android:textColor="#A3BFFA"
                                android:textSize="26sp"
                                android:textStyle="bold"
                                android:background="#1E3A6E" />
                        </LinearLayout>

                        <!-- CalendarView -->
                        <CalendarView
                            android:id="@+id/calendarView"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@android:color/transparent"
                            android:selectedWeekBackgroundColor="#3B5BDB"
                            android:focusedMonthDateColor="#FFFFFF"
                            android:unfocusedMonthDateColor="#4A6090"
                            android:weekNumberColor="#7B9ED9" />

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Add Event Button — normal Button, NO drawable, NO FAB -->
                <Button
                    android:id="@+id/addEventBtn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="16dp"
                    android:text="+ Add Reminder"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:backgroundTint="#3B5BDB"
                    android:paddingStart="24dp"
                    android:paddingEnd="24dp"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp" />

                <!-- Reminders Section -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="⏰ My Reminders"
                    android:textColor="#FFFFFF"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:layout_marginStart="20dp"
                    android:layout_marginEnd="20dp"
                    android:layout_marginTop="20dp"
                    android:layout_marginBottom="12dp"/>

                <!-- REMINDERS LIST -->
                <LinearLayout
                    android:id="@+id/remindersContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp"
                    android:background="@drawable/calendar_bg"/>

            </LinearLayout>
        </ScrollView>
    </LinearLayout>

    <!-- Navigation Drawer -->
    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navigationview"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="#0F1B35"
        app:menu="@menu/drawer_menu"
        app:headerLayout="@layout/nav_header"
        app:itemTextColor="#FFFFFF"
        app:itemIconTint="#A3BFFA" />

</androidx.drawerlayout.widget.DrawerLayout>