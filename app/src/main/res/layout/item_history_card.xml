<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/gradient2"
    android:layout_marginTop="6dp"
    android:layout_marginBottom="6dp">

    <!-- Top Row: Details + Delete Button -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="14dp"
        android:gravity="center_vertical">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <!-- Standard | Stream -->
            <TextView
                android:id="@+id/tvStandard"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textStyle="bold"
                android:textSize="16sp"
                android:textColor="@android:color/black" />

            <!-- Exam Type (only for Exam, gone for Timetable) -->
            <TextView
                android:id="@+id/tvExtraInfo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textColor="@android:color/black"
                android:visibility="gone" />

            <!-- Info text -->
            <TextView
                android:id="@+id/tvInfo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textColor="#444444"
                android:maxLines="2"
                android:ellipsize="end"
                android:visibility="gone" />

            <!-- Timestamp -->
            <TextView
                android:id="@+id/tvTimestamp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="#444444" />

        </LinearLayout>

        <!-- Red Delete Icon (transparent background like reference) -->
        <ImageButton
            android:id="@+id/btnDelete"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@android:drawable/ic_menu_delete"
            android:background="@android:color/transparent"
            android:contentDescription="Delete"
            app:tint="#D32F2F" />

    </LinearLayout>

    <!-- Image Preview (visible only if image was uploaded) -->
    <ImageView
        android:id="@+id/ivHistoryImage"
        android:layout_width="match_parent"
        android:layout_height="250dp"
        android:scaleType="centerCrop"
        android:visibility="gone"
        android:layout_marginLeft="14dp"
        android:layout_marginRight="14dp"
        android:layout_marginBottom="8dp"
        android:contentDescription="Uploaded Image"/>

    <!-- Seen / Unseen Buttons Row -->
    <LinearLayout
        android:id="@+id/llSeenUnseen"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingBottom="12dp"
        android:gravity="center">

        <Button
            android:id="@+id/btnSeen"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:text="👁 Seen (0)"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:backgroundTint="#2E7D32"
            android:layout_marginEnd="6dp" />

        <Button
            android:id="@+id/btnUnseen"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:text="🚫 Unseen (0)"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:backgroundTint="#D32F2F"
            android:layout_marginStart="6dp" />

    </LinearLayout>

</LinearLayout>