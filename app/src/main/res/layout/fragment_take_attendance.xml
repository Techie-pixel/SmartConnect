<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Info Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="#1A2744"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:id="@+id/tvClassInfo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Class: --"
                    android:textColor="#4FC3F7"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvSubjectInfo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Subject: --"
                    android:textColor="#CCDDFF"
                    android:textSize="14sp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Date Selection -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Select Date"
            android:textColor="@android:color/white"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginBottom="6dp"/>

        <TextView
            android:id="@+id/tvSelectedDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Today"
            android:background="@drawable/gradient2"
            android:textStyle="bold"
            android:textSize="16sp"
            android:padding="14dp"
            android:textColor="@android:color/black"
            android:layout_marginBottom="16dp"/>

        <!-- Load Students Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLoadStudents"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Load Students"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:layout_marginBottom="16dp"
            android:backgroundTint="#1B477C"
            android:textColor="#FFFFFF"
            app:cornerRadius="12dp"/>

        <!-- Students List -->
        <TextView
            android:id="@+id/tvStudentCount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Students"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"
            android:visibility="gone"/>

        <LinearLayout
            android:id="@+id/studentsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/calendar_bg"
            android:layout_marginBottom="16dp"
            android:padding="8dp"/>

        <!-- Submit Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSubmitAttendance"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Submit Attendance"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:layout_marginBottom="24dp"
            android:backgroundTint="#0A2C56"
            android:textColor="#FFFFFF"
            android:visibility="gone"
            app:cornerRadius="12dp"/>

    </LinearLayout>
</ScrollView>
