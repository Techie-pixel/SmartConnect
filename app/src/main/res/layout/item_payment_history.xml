<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#22FFFFFF"
    android:padding="12dp"
    android:layout_marginBottom="8dp">

    <!-- Date & Type Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tvPayDate"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="01-01-2026"
            android:textColor="#CCCCCC"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/tvPayType"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Installment"
            android:textColor="#4FC3F7"
            android:textSize="13sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Amount Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="4dp">

        <TextView
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="Amount Paid:"
            android:textColor="#AAAAAA"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/tvPayAmount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="₹ 0"
            android:textColor="#66BB6A"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Download Receipt Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnDownloadItemReceipt"
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:layout_marginTop="8dp"
        android:text="⬇ Download Receipt"
        android:textSize="12sp"
        android:textAllCaps="false"
        app:cornerRadius="8dp"
        app:backgroundTint="#2E7D32"
        style="@style/Widget.MaterialComponents.Button" />

</LinearLayout>
