<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/gradient1">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <androidx.appcompat.widget.Toolbar
            app:titleTextColor="#FFFFFF"
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:background="#1B477C"
            android:paddingTop="20dp"
            android:theme="@style/ThemeOverlay.AppCompat.Light" />

        <!-- SCROLLABLE CONTENT -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <LinearLayout
                android:id="@+id/contentLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- LOGO -->
                <ImageView
                    android:id="@+id/logoImg"
                    android:layout_width="300dp"
                    android:layout_height="300dp"
                    android:layout_gravity="center"
                    android:src="@drawable/projectlogo"
                    android:contentDescription="Logo"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="16dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Principal Calendar"
                    android:textColor="@android:color/white"
                    android:textStyle="bold"
                    android:textSize="25dp"
                    android:layout_gravity="center"
                    android:layout_marginBottom="50dp"/>

                <!-- SELECTED DATE -->
                <TextView
                    android:id="@+id/selectedDateText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Today"
                    android:background="@drawable/gradient2"
                    android:textStyle="bold"
                    android:textSize="18sp"
                    android:padding="10dp"
                    android:textColor="@android:color/black"
                    android:layout_marginBottom="20dp"/>

                <!-- CALENDAR with dark background -->
                <CalendarView
                    android:id="@+id/calendarView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:firstDayOfWeek="2"
                    android:background="@drawable/calendar_bg"
                    android:dateTextAppearance="@style/CalendarDateText"
                    android:weekDayTextAppearance="@style/CalendarWeekDayText"
                    android:layout_marginBottom="12dp"/>

                <!-- TIME LABEL -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Current Time"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:layout_marginTop="30dp"
                    android:textStyle="bold"
                    android:layout_marginBottom="4dp"/>

                <!-- CLOCK -->
                <TextClock
                    android:id="@+id/textClock"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:format12Hour="hh:mm a"
                    android:textColor="#FFFFFF"
                    android:textSize="32sp"
                    android:background="@drawable/calendar_bg"
                    android:padding="12dp"
                    android:textStyle="bold"
                    android:layout_marginBottom="20dp"/>

                <!-- REMINDERS SECTION -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="⏰ My Reminders"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>

                <!-- ADD REMINDER BUTTON -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/addReminderBtn"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="+ Add Reminder"
                    android:padding="15dp"
                    android:backgroundTint="#1B477C"
                    android:textColor="#FFFFFF"
                    android:layout_marginBottom="12dp"/>

                <!-- REMINDERS LIST -->
                <LinearLayout
                    android:id="@+id/remindersContainer"
                    android:background="@drawable/calendar_bg"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"/>

            </LinearLayout>
        </ScrollView>
    </LinearLayout>

    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navigationview"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="#0A1628"
        app:menu="@menu/principal_drawer_menu"
        app:headerLayout="@layout/nav_header"
        app:itemTextColor="#FFFFFF"
        app:itemIconTint="#A3BFFA" />

</androidx.drawerlayout.widget.DrawerLayout>
