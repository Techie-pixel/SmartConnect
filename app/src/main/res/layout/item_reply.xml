<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="6dp"
    android:paddingStart="8dp"
    android:paddingEnd="8dp">

    <!-- Admin reply (right aligned) -->
    <LinearLayout
        android:id="@+id/adminBubble"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end"
        android:orientation="vertical"
        android:background="#2E5090"
        android:padding="12dp"
        android:maxWidth="280dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/tvAdminLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Admin"
            android:textColor="#4FC3F7"
            android:textSize="11sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tvAdminMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:layout_marginTop="2dp"/>

        <TextView
            android:id="@+id/tvAdminTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#AAAAAA"
            android:textSize="10sp"
            android:layout_marginTop="2dp"
            android:layout_gravity="end"/>
    </LinearLayout>

    <!-- User reply (left aligned) -->
    <LinearLayout
        android:id="@+id/userBubble"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="start"
        android:orientation="vertical"
        android:background="#1A2744"
        android:padding="12dp"
        android:maxWidth="280dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/tvUserLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="You"
            android:textColor="#81C784"
            android:textSize="11sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tvUserMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:layout_marginTop="2dp"/>

        <TextView
            android:id="@+id/tvUserTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#AAAAAA"
            android:textSize="10sp"
            android:layout_marginTop="2dp"
            android:layout_gravity="end"/>
    </LinearLayout>
</FrameLayout>
