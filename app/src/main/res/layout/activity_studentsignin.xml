<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".studentsignin"
    android:background="@drawable/gradient1">

    <LinearLayout
        android:id="@+id/main_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <ImageView
            android:layout_width="400dp"
            android:layout_height="350dp"
            android:layout_gravity="center"
            android:contentDescription="App Logo"
            android:src="@drawable/projectlogo" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Student Login"
            android:textColor="@color/white"
            android:gravity="center"
            android:textStyle="bold"
            android:textSize="30dp">
        </TextView>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Learning is the key to success"
            android:textColor="@color/white"
            android:gravity="center"
            android:layout_marginTop="12dp"
            android:textStyle="bold"
            android:textSize="15dp">
        </TextView>

        <!-- Name -->
        <EditText
            android:id="@+id/username"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:hint="Enter Your Name"
            android:layout_marginTop="20dp"
            android:background="@drawable/gradient2"
            android:padding="14dp"
            android:textColor="@color/black"
            android:textColorHint="#100F0F"/>

        <!-- Email -->
        <EditText
            android:id="@+id/useremail"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:hint="Enter Your Email"
            android:layout_marginTop="20dp"
            android:background="@drawable/gradient2"
            android:padding="14dp"
            android:textColor="@color/black"
            android:textColorHint="#100F0F"
            android:inputType="textEmailAddress" />

        <!-- Password -->
        <EditText
            android:id="@+id/userpassword"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Enter Password"
            android:padding="15dp"
            android:inputType="textPassword"
            android:textColor="@color/black"
            android:textColorHint="#100F0F"
            android:layout_marginTop="20dp"
            android:background="@drawable/gradient2"
            android:drawableEnd="@drawable/eyeoff"
            android:drawablePadding="10dp"/>

        <!-- Mobile -->
        <EditText
            android:id="@+id/usermobile"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:hint="Enter your mobile no."
            android:layout_marginTop="20dp"
            android:background="@drawable/gradient2"
            android:padding="14dp"
            android:textColor="@color/black"
            android:textColorHint="#100F0F"
            android:inputType="phone" />

        <!-- Select Standard -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Select Standard"
            android:layout_marginTop="20dp"
            android:textStyle="bold"
            android:textColor="@color/white" />

        <Spinner
            android:id="@+id/spinnerStandard"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:background="@drawable/gradient2"
            android:padding="14dp"
            android:spinnerMode="dropdown" />

        <!-- Select Stream -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Select Stream"
            android:layout_marginTop="20dp"
            android:textStyle="bold"
            android:textColor="@color/white" />

        <Spinner
            android:id="@+id/spinnerStream"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:background="@drawable/gradient2"
            android:padding="14dp"
            android:spinnerMode="dropdown" />

        <!-- Sign Up Button -->
        <Button
            android:id="@+id/userbutton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Sign Up"
            android:textSize="18dp"
            android:textStyle="bold"
            android:layout_marginTop="20dp"
            android:backgroundTint="#0A2C56"
            android:padding="14dp"
            android:textColor="@color/white" />

        <TextView
            android:id="@+id/signin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center"
            android:text="Already have an account? Login!!"
            android:textColor="@color/white"
            android:textSize="18dp"
            android:textStyle="bold" />

    </LinearLayout>
</ScrollView>
