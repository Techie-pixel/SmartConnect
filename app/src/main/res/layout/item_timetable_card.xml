<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="14dp"
    android:layout_marginEnd="14dp"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="#112244">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:id="@+id/tvTimetableLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📋 Timetable"
                android:textColor="#A3BFFA"
                android:textSize="13sp"
                android:textStyle="bold" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/tvTimetableDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="01 Jan 2026"
                android:textColor="#7B9ED9"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Image -->
        <ImageView
            android:id="@+id/ivTimetableImage"
            android:layout_width="match_parent"
            android:layout_height="250dp"
            android:scaleType="centerCrop"
            android:visibility="visible"
            android:layout_marginTop="10dp"
            android:contentDescription="Timetable Image" />

        <!-- View Fullscreen Hint -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tap image to view full screen"
            android:textSize="12sp"
            android:textColor="#A3BFFA"
            android:textStyle="italic"
            android:gravity="center"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="4dp"/>

        <!-- Unread Badge / Mark as Read -->
        <LinearLayout
            android:id="@+id/llReadAction"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="12dp">

            <TextView
                android:id="@+id/tvUnreadBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="● NEW"
                android:textColor="#F87171"
                android:textSize="11sp"
                android:textStyle="bold"
                android:visibility="gone" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <Button
                android:id="@+id/btnDownloadImage"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:text="⬇ Download"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:backgroundTint="#0288D1"
                android:layout_marginEnd="8dp" />

            <Button
                android:id="@+id/btnMarkRead"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:text="✓ Mark as Read"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:backgroundTint="#2E7D32" />
        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>
