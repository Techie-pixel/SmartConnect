<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/gradient1">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:background="#1B477C"
        android:paddingTop="20dp"
        app:titleTextColor="#FFFFFF"
        app:title="Attendance"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:gravity="center_horizontal">

            <!-- Top Icon -->
            <ImageView
                android:id="@+id/logoImg"
                android:layout_width="300dp"
                android:layout_height="300dp"
                android:src="@drawable/projectlogo"
                android:contentDescription="Logo"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="10dp"/>

            <!-- Search Header -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardSearch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="#1A2744"
                app:cardCornerRadius="12dp"
                app:cardElevation="6dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="🔍 Find Student Attendance"
                        android:textColor="#4FC3F7"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="12dp"/>

                    <EditText
                        android:id="@+id/etStudentId"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Student ID or Name (exact)"
                        android:textColorHint="#777777"
                        android:textColor="#FFFFFF"
                        android:backgroundTint="#334466"
                        android:padding="12dp"
                        android:inputType="text"
                        android:layout_marginBottom="10dp"/>

                    <Spinner
                        android:id="@+id/spinnerStandard"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:background="@drawable/gradient2"
                        android:padding="10dp"
                        android:layout_marginBottom="10dp"/>

                    <Spinner
                        android:id="@+id/spinnerStream"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:background="@drawable/gradient2"
                        android:padding="10dp"
                        android:layout_marginBottom="14dp"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSearch"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Search Attendance"
                        android:textAllCaps="false"
                        android:textStyle="bold"
                        android:backgroundTint="#1B477C"
                        android:textColor="#FFFFFF"
                        app:cornerRadius="10dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Summary Card (hidden until search) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardSummary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:visibility="gone"
                app:cardBackgroundColor="#0D1B2A"
                app:cardCornerRadius="12dp"
                app:cardElevation="6dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/tvStudentNameResult"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Student Name"
                        android:textColor="#FFFFFF"
                        android:textSize="17sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="10dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:background="#1B5E20"
                            android:padding="12dp"
                            android:layout_marginEnd="4dp">
                            <TextView
                                android:id="@+id/tvSumPresent"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textColor="#A5D6A7"
                                android:textSize="22sp"
                                android:textStyle="bold"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Present"
                                android:textColor="#A5D6A7"
                                android:textSize="11sp"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:background="#B71C1C"
                            android:padding="12dp"
                            android:layout_marginEnd="4dp">
                            <TextView
                                android:id="@+id/tvSumAbsent"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textColor="#FFCDD2"
                                android:textSize="22sp"
                                android:textStyle="bold"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Absent"
                                android:textColor="#FFCDD2"
                                android:textSize="11sp"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:background="#E65100"
                            android:padding="12dp"
                            android:layout_marginEnd="4dp">
                            <TextView
                                android:id="@+id/tvSumLate"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textColor="#FFE0B2"
                                android:textSize="22sp"
                                android:textStyle="bold"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Late"
                                android:textColor="#FFE0B2"
                                android:textSize="11sp"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:background="#1B477C"
                            android:padding="12dp">
                            <TextView
                                android:id="@+id/tvSumPct"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0%"
                                android:textColor="#90CAF9"
                                android:textSize="22sp"
                                android:textStyle="bold"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Attend%"
                                android:textColor="#90CAF9"
                                android:textSize="11sp"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Date Records -->
            <TextView
                android:id="@+id/tvRecordsHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Date-wise Records"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"
                android:visibility="gone"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvDateRecords"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"/>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
